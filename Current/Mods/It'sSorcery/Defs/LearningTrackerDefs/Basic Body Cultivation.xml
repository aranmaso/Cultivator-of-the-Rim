		<description>foundation of body cultivation for cultivator who aimed toward body building.</description>
		
		<prereqSkills>
			<li>
				<mode>GreaterEqual</mode>
				<skillReqs>
					<li>
						<skillDef>Melee</skillDef>
						<level>5</level>
					</li>
				</skillReqs>
			</li>
		</prereqSkills>
		
		<prereqStats>
		<li>
			<mode>Lesser</mode>
			<statReqs>
